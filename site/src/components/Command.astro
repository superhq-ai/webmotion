---
// A command line you can take with you. The button writes to the clipboard and
// reports back in place; if the browser refuses (insecure context, denied
// permission) it selects the text instead so the command is still one keystroke
// away rather than lost behind a dead button.
interface Props {
  cmd: string;
  label: string;
}
const { cmd, label } = Astro.props;
---

<div class="flex items-center gap-4 bg-bg px-4 py-3">
  <!-- Fixed width so the commands start on a common left edge down the stack. -->
  <span class="micro w-[9.5rem] flex-none">{label}</span>
  <code class="min-w-0 flex-1 overflow-x-auto font-mono text-[0.8125rem] whitespace-nowrap text-ink"
    >{cmd}</code
  >
  <button
    type="button"
    data-copy={cmd}
    class="copy-btn flex size-7 flex-none items-center justify-center rounded-[3px] text-ink-4 transition-colors hover:bg-chip hover:text-ink"
  >
    <span class="sr-only">Copy command</span>
    <svg class="i-copy" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.3"
        d="M5.5 5.5v-3h8v8h-3M2.5 5.5h8v8h-8z"></path>
    </svg>
    <svg class="i-done hidden" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3 8.5 6.5 12 13 4.5"></path>
    </svg>
  </button>
</div>
